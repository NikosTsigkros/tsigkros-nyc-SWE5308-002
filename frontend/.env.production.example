# Copy to .env.production locally, or set the same key in DigitalOcean
# (Static Site / Web Service → Environment → Build-time / Build command env).
#
# Examples (axios normalizes so Django always sees …/api/…):
# - App route `/backend` → https://your-app.ondigitalocean.app/backend  (→ …/backend/api)
# - API at root /api → https://your-app.ondigitalocean.app/api
VITE_API_URL=https://your-app.ondigitalocean.app/backend
